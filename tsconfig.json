{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "ESNext",
        "outDir": "dist",
        "rootDir": "src",
        "composite": false,
        "declaration": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "emitDeclarationOnly": true,
        "lib": [
            "esnext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@errors/*": [
                "./src/errors/*"
            ],
            "@services/*": [
                "./src/services/*"
            ],
            "@providers/*": [
                "./src/providers/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@shared/*": [
                "./src/modules/shared/*"
            ],
            "@targets/*": [
                "./src/modules/targets/*"
            ],
            "@reports/*": [
                "./src/modules/reports/*"
            ],
            "@packets/*": [
                "./src/modules/packets/*"
            ],
            "@symlinks/*": [
                "./src/modules/symlinks/*"
            ],
            "@messages/*": [
                "./src/modules/messages/*"
            ],
            "@configuration/*": [
                "./src/configuration/*"
            ]
        }
    },
    "include": [
        "src/index.ts",
        "includes/**/*.ts",
        "src/modules/shared/shared.module.ts"
    ],
    "exclude": [
        "dist",
        "**/*.spec.ts",
        "node_modules"
    ],
    "references": [
        { "path": "./tsconfig.spec.json" }
    ]
}
