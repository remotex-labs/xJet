{
    "name": "@remotex-labs/xjet",
    "type": "module",
    "main": "dist/index.js",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "author": "Garefild",
    "version": "1.0.0-local",
    "license": "Mozilla Public License Version 2.0",
    "description": "xJet: Run Automated Tests Anywhere, Effortlessly",
    "homepage": "https://remotex-labs.github.io/xJet/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/remotex-labs/xJet.git"
    },
    "bugs": {
        "url": "https://github.com/remotex-labs/xJet/issues"
    },
    "keywords": [
        "jet",
        "xjet",
        "test",
        "jest",
        "mocha",
        "watch",
        "testing",
        "mocking",
        "jasmine",
        "coverage",
        "typescript"
    ],
    "engines": {
        "node": ">=20"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "bin": {
        "jet": "./dist/bash.js",
        "xjet": "./dist/bash.js",
        "xJet": "./dist/bash.js"
    },
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "jest",
        "test:coverage":    "jest --coverage",

        "lint":             "pnpm lint:md && pnpm lint:eslint && pnpm lint:typescript",
        "lint:md":          "markdownlint \"**/*.md\" --ignore node_modules",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc",

        "docs:dev":         "vitepress dev docs",
        "docs:build":       "vitepress build docs",
        "docs:preview":     "vitepress preview docs",

        "ci":              "pnpm lint && pnpm test && pnpm build:clean",
        "prepublishOnly":  "pnpm lint && pnpm test && pnpm build:clean"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "eslint": "^10.2.0",
        "vitepress": "^2.0.0-alpha.12",
        "markdownlint-cli": "^0.48.0",
        "typescript-eslint": "^8.58.2",
        "eslint-plugin-tsdoc": "^0.5.2",
        "eslint-plugin-perfectionist": "^5.8.0",
        "@swc/jest": "^0.2.39",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.0",
        "@types/yargs": "^17.0.35",
        "@viteplus/versions": "^2.0.2",
        "@remotex-labs/xbuild": "^2.4.0"
    },
    "dependencies": {
        "yargs": "^18.0.0",
        "esbuild": "^0.28.0",
        "typescript": "^6.0.2",
        "@remotex-labs/xmap": "^5.1.0",
        "@remotex-labs/xansi": "^1.3.7",
        "@remotex-labs/xstruct": "^2.1.3",
        "@remotex-labs/xjet-expect": "^2.1.4"
    }
}
